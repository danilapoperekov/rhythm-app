# Copy values into your local shell or hosting secrets. Do not commit real secrets.

# Local server
PORT=4173
NODE_ENV=development
RHYTHM_ACCESS_TOKEN=

# Default hosted text and speech provider
OPENAI_API_KEY=
RHYTHM_AI_MODEL=gpt-5.6-terra

# Optional local or external OpenAI-compatible text model, for example Bonsai 27B via llama.cpp/vLLM.
RHYTHM_LLM_PROVIDER=openai
RHYTHM_LLM_BASE_URL=http://127.0.0.1:8080/v1
RHYTHM_LLM_MODEL=prism-ml/Bonsai-27B-gguf
RHYTHM_LLM_API_KEY=

# Public Worker CORS allowlist
RHYTHM_ALLOWED_ORIGINS=https://danilapoperekov.github.io,http://localhost:4173,http://127.0.0.1:4173
